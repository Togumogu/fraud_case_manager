                "variablePath": "message.debitaccount.number",
                "dataType": "string"
              }
            ]
          }
        ]
      }      
	
	

    
Transaction Viewer:


    {
      "post": "/alertsTransaction/transactionViewerConfig",
      "contentType": "application/vnd.sas.triage.transaction.viewer.config+json",
      "acceptType": "application/json",
      "body": [
        {
          "id": "debit_account_transaction_viewer",
          "optLockVersion": -1,
          "indexableVariablePath": "message.debitaccount.number",
          "alertFieldValuePath": "actionableEntityID",
          "transactionGridDefinitionConfigs": [
            {
              "id": "check_transaction_grid",
              "displayOrderVal": 1
            },
            {
              "id": "debit_card_transaction_grid",
              "displayOrderVal": 0
            }
          ],
          "transactionMarkConfigs": [
            { "id": "review-required" },
            { "id": "review-in-progress" },
            { "id": "reviewed-inconclusive" },
            { "id": "declined" },
            { "id": "authorized" }
          ]
        },
        {
          "id": "check_transaction_viewer",
          "optLockVersion": -1,
          "indexableVariablePath": "message.debitaccount.number",
          "alertFieldValuePath": "actionableEntityID",
          "transactionGridDefinitionConfigs": [
            {
              "id": "check_transaction_grid",
              "displayOrderVal": 0
            },
            {
              "id": "debit_card_transaction_grid",
              "displayOrderVal": 1
            }
          ],
          "transactionMarkConfigs": [
            { "id": "review-required" },
            { "id": "review-in-progress" },
            { "id": "reviewed-inconclusive" },
            { "id": "declined" },
            { "id": "authorized" }
          ]
        }
      ]
    }    
    
